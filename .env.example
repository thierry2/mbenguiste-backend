# --- Serveur ---
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# --- Supabase ---
# service_role : contourne la RLS. NE JAMAIS exposer côté frontend.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Traduction des messages (optionnel) ---
# Vide → la traduction dans le chat est désactivée (fail-open, jamais bloquant).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
