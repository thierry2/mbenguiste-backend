{
  "name": "mbenguiste-backend",
  "version": "0.1.0",
  "description": "API backend pour Mbenguiste — l'amour par-delà les frontières.",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node scripts/seed.js",
    "seed:partner": "node scripts/seed-partner.js",
    "test": "node --test --test-concurrency=1 \"tests/**/*.test.js\"",
    "lint": "eslint ."
  },
  "keywords": [
    "mbenguiste",
    "dating",
    "express",
    "api"
  ],
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@huggingface/transformers": "^4.2.0",
    "@supabase/supabase-js": "^2.108.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.0",
    "sharp": "^0.35.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@electric-sql/pglite-pgvector": "^0.0.5",
    "eslint": "^9.7.0",
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "@huggingface/transformers": {
      "sharp": "$sharp"
    }
  }
}
